    {
      "function": "activeFailureRefetchThrottleMs",
      "note": "a huge streak is overflow-safe both sides (JS Infinity, Rust checked_shl saturate)",
      "input": { "streak": 1000000 },
      "expected": 900000
    },
    {
      "function": "activeFailureRefetchThrottleMs",
      "note": "a negative streak clamps to 0 on both adapters -> base wait",
