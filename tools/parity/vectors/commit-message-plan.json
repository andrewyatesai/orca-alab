{
  "module": "commit-message-plan",
  "source": "src/shared/commit-message-plan.ts",
  "rustCrate": "orca-agents::commit_message_plan",
  "cases": [
    {
      "function": "planCommitMessageGeneration",
      "note": "Claude: prompt on stdin only (stdinPayload set, args carry no positional prompt)",
      "input": {
        "planInput": {
          "agentId": "claude",
          "model": "sonnet",
          "thinkingLevel": "high"
        },
        "prompt": "PROMPT"
      },
      "expected": {
        "ok": true,
        "plan": {
          "binary": "claude",
          "args": [
            "-p",
            "--output-format",
            "text",
            "--model",
            "sonnet",
            "--permission-mode",
            "plan",
            "--effort",
            "high"
          ],
          "stdinPayload": "PROMPT",
          "label": "Claude"
        }
      }
    },
    {
      "function": "planCommitMessageGeneration",
      "note": "OpenCode: prompt on stdin only (issue #4859); args carry no positional prompt",
      "input": {
        "planInput": {
