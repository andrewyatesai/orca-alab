{
  "module": "task-query",
  "source": "src/shared/task-query.ts",
  "rustCrate": "orca-core::task_query",
  "cases": [
    {
      "function": "tokenizeSearchQuery",
      "note": "splits on whitespace",
      "input": "is:open assignee:@me foo",
      "expected": ["is:open", "assignee:@me", "foo"]
    },
    {
      "function": "tokenizeSearchQuery",
      "note": "unwraps standalone double-quoted tokens",
      "input": "\"needs review\" foo",
      "expected": ["needs review", "foo"]
    },
    {
      "function": "tokenizeSearchQuery",
      "note": "unwraps standalone single-quoted tokens",
      "input": "'with spaces' bar",
      "expected": ["with spaces", "bar"]
    },
    {
      "function": "tokenizeSearchQuery",
      "note": "keeps quoted qualifier values as one token",
      "input": "label:\"needs review\" author:alice",
      "expected": ["label:needs review", "author:alice"]
    },
    {
      "function": "tokenizeSearchQuery",
      "note": "returns an empty list for an empty string",
      "input": "",
      "expected": []
    },
    {
      "function": "tokenizeSearchQuery",
      "note": "whitespace-only input yields no tokens",
      "input": "   ",
      "expected": []
    },
    {
      "function": "tokenizeSearchQuery",
      "note": "collapses runs of whitespace and ignores leading/trailing gaps",
      "input": "  foo   bar  ",
      "expected": ["foo", "bar"]
    },
    {
      "function": "parseTaskQuery",
      "note": "returns defaults for an empty query",
      "input": "",
      "expected": {
        "scope": "all",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "parses is:issue and is:open",
      "input": "is:issue is:open",
      "expected": {
        "scope": "issue",
        "state": "open",
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
