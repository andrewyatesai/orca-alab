    {
      "function": "activeFailureRefetchThrottleMs",
      "note": "each further failure doubles: streak 2 = 2^1",
      "input": { "streak": 2 },
      "expected": 60000
    },
    {
      "function": "activeFailureRefetchThrottleMs",
      "note": "streak 3 = 2^2",
      "input": { "streak": 3 },
      "expected": 120000
    },
    {
      "function": "activeFailureRefetchThrottleMs",
      "note": "streak 4 = 2^3",
      "input": { "streak": 4 },
      "expected": 240000
    },
    {
      "function": "activeFailureRefetchThrottleMs",
      "note": "streak 5 = 2^4, still below the ceiling",
      "input": { "streak": 5 },
      "expected": 480000
