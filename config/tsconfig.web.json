{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "../src/renderer/src/env.d.ts",
    "../src/renderer/src/**/*",
    "../src/renderer/src/**/*.tsx",
    "../src/renderer/coordinator/**/*",
    "../src/preload/api-types.ts",
    "../src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@renderer/*": ["../src/renderer/src/*"],
      "@/*": ["../src/renderer/src/*"]
    }
  }
}
