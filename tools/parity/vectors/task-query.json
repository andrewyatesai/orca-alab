        "draft": false,
        "assignee": "octo cat",
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      },
      "expected": "is:issue is:closed assignee:\"octo cat\""
    },
    {
      "function": "withQualifier",
      "note": "sets the author qualifier without disturbing free text",
      "input": { "rawQuery": "hello", "key": "author", "value": "alice" },
      "expected": "author:alice hello"
    },
    {
      "function": "withQualifier",
      "note": "clears the author qualifier (null value) and keeps free text",
      "input": { "rawQuery": "author:alice hello", "key": "author", "value": null },
      "expected": "hello"
    },
    {
      "function": "withQualifier",
      "note": "replaces the labels list with the provided array",
      "input": { "rawQuery": "label:bug label:enh", "key": "labels", "value": ["triage"] },
      "expected": "label:triage"
    },
    {
      "function": "withQualifier",
      "note": "clears labels when given an empty array, preserving other scope",
      "input": { "rawQuery": "label:bug is:pr", "key": "labels", "value": [] },
      "expected": "is:pr"
    },
    {
      "function": "withQualifier",
      "note": "sets the all state filter",
      "input": { "rawQuery": "is:pr is:open", "key": "state", "value": "all" },
      "expected": "is:pr state:all"
    },
    {
      "function": "withQualifier",
      "note": "preserves quoted free-text tokens when applying a filter",
      "input": {
        "rawQuery": "\"exact phrase\" milestone:\"next release\"",
        "key": "author",
        "value": "alice"
      },
      "expected": "author:alice \"exact phrase\" milestone:\"next release\""
    },
    {
      "function": "withQualifier",
      "note": "draft=true forces pr scope and open state",
      "input": { "rawQuery": "", "key": "draft", "value": "true" },
      "expected": "is:pr is:open is:draft"
    },
    {
      "function": "withQualifier",
      "note": "state=merged forces pr scope",
      "input": { "rawQuery": "", "key": "state", "value": "merged" },
      "expected": "is:pr is:merged"
    },
    {
      "function": "withQualifier",
      "note": "reviewRequested forces pr scope",
      "input": { "rawQuery": "", "key": "reviewRequested", "value": "@me" },
      "expected": "is:pr review-requested:@me"
    },
    {
      "function": "withQualifier",
      "note": "draft filter forces a closed PR back to open",
      "input": { "rawQuery": "is:pr is:closed", "key": "draft", "value": "true" },
      "expected": "is:pr is:open is:draft"
    },
    {
      "function": "withQualifier",
      "note": "sets the assignee qualifier alongside an existing state token",
      "input": { "rawQuery": "is:open", "key": "assignee", "value": "octocat" },
      "expected": "is:open assignee:octocat"
    },
    {
      "function": "withQualifier",
      "note": "null state value clears the state qualifier",
      "input": { "rawQuery": "is:pr is:open", "key": "state", "value": null },
      "expected": "is:pr"
    },
    {
      "function": "stripRepoQualifiers",
      "note": "removes repo:owner/name tokens",
      "input": "is:open repo:foo/bar assignee:@me",
      "expected": "is:open assignee:@me"
    },
    {
      "function": "stripRepoQualifiers",
      "note": "is case-insensitive on the repo: key",
      "input": "REPO:Foo/Bar is:open",
      "expected": "is:open"
    },
    {
      "function": "stripRepoQualifiers",
      "note": "keeps other qualifiers intact",
      "input": "label:bug repo:a/b",
      "expected": "label:bug"
    },
    {
      "function": "stripRepoQualifiers",
      "note": "re-quotes a standalone token that contains whitespace",
      "input": "\"needs review\" repo:x/y",
      "expected": "\"needs review\""
    },
    {
      "function": "stripRepoQualifiers",
      "note": "re-quotes a qualifier value that contains whitespace",
      "input": "label:\"needs review\" repo:a/b",
      "expected": "label:\"needs review\""
    },
    {
      "function": "stripRepoQualifiers",
      "note": "returns empty string when only repo qualifiers are present",
      "input": "repo:foo/bar repo:baz/qux",
      "expected": ""
    },
    {
      "function": "stripRepoQualifiers",
      "note": "preserves a bare word containing no space",
      "input": "hello repo:a/b world",
      "expected": "hello world"
    },
    {
      "function": "stripRepoQualifiers",
      "note": "a repo token split by whitespace only drops the matching half",
      "input": "repo:foo bar",
      "expected": "bar"
    },
    {
      "function": "stripRepoQualifiers",
      "note": "empty input yields empty output",
      "input": "",
      "expected": ""
    }
