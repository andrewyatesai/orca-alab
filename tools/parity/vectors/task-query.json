      "expected": {
        "scope": "pr",
        "state": "open",
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "widens scope to all when both is:issue and is:pr are present",
      "input": "is:issue is:pr",
      "expected": {
        "scope": "all",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "widens scope to all regardless of issue and PR token order",
      "input": "is:pr is:issue",
      "expected": {
        "scope": "all",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "is:draft forces scope to pr and state to open",
      "input": "is:draft",
      "expected": {
        "scope": "pr",
        "state": "open",
        "draft": true,
