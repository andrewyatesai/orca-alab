{
  "module": "setup-script-imports",
  "source": "src/shared/setup-script-imports.ts",
  "rustCrate": "orca-config::setup_script_imports",
  "cases": [
    {
      "function": "inspectSetupScriptImportCandidates",
      "note": "Superset base config: setup/teardown arrays import; run and cwd are unsupported",
      "input": {
        "contentsByPath": {
          ".superset/config.json": "{\"setup\":[\"./.superset/setup.sh\",\"bun install\"],\"teardown\":[\"./.superset/teardown.sh\"],\"run\":[\"bun dev\"],\"cwd\":\"packages/web\"}"
        }
      },
      "expected": [
        {
          "provider": "superset",
          "label": "Superset",
          "files": [
            ".superset/config.json"
          ],
          "setup": "./.superset/setup.sh\nbun install",
          "archive": "./.superset/teardown.sh",
          "unsupportedFields": [
            "run",
            "cwd"
          ]
        }
      ]
    },
    {
      "function": "inspectSetupScriptImportCandidates",
      "note": "Superset local overlay: before/after wrap base setup, local teardown overrides, extra local fields flagged",
      "input": {
        "contentsByPath": {
          ".superset/config.json": "{\"setup\":[\"bun install\"],\"teardown\":[\"docker compose down\"],\"cwd\":\"packages/web\"}",
          ".superset/config.local.json": "{\"setup\":{\"before\":[\"corepack enable\"],\"after\":[\"bun run db:migrate\"],\"cwd\":\"packages/api\"},\"teardown\":[\"docker compose down --remove-orphans\"],\"run\":[\"bun dev\"]}"
        }
      },
      "expected": [
        {
          "provider": "superset",
          "label": "Superset",
          "files": [
            ".superset/config.json",
            ".superset/config.local.json"
          ],
          "setup": "corepack enable\nbun install\nbun run db:migrate",
          "archive": "docker compose down --remove-orphans",
          "unsupportedFields": [
            "cwd",
            "config.local.run",
            "config.local.setup.cwd"
          ]
        }
      ]
    },
    {
      "function": "inspectSetupScriptImportCandidates",
      "note": "Conductor config: setup + archive import; top-level and script fields flagged",
      "input": {
        "contentsByPath": {
          "conductor.json": "{\"scripts\":{\"setup\":\"pnpm install\",\"archive\":\"pnpm run archive\",\"run\":\"pnpm dev\",\"teardown\":\"pnpm clean\"},\"enterpriseDataPrivacy\":true,\"runScriptMode\":\"auto\"}"
        }
      },
      "expected": [
        {
          "provider": "conductor",
          "label": "Conductor",
          "files": [
            "conductor.json"
          ],
          "setup": "pnpm install",
          "archive": "pnpm run archive",
          "unsupportedFields": [
            "enterpriseDataPrivacy",
            "runScriptMode",
            "scripts.run",
            "scripts.teardown"
          ]
        }
      ]
    },
    {
      "function": "inspectSetupScriptImportCandidates",
      "note": "Codex environment.toml: multiline setup + literal cleanup; actions assignment and section flagged",
      "input": {
        "contentsByPath": {
          ".codex/environments/environment.toml": "# Codex environment\n\n[setup]\nscript = \"\"\"\nnpm ci\npnpm build\n\"\"\"\n\n[cleanup]\nscript = 'pnpm clean'\n\nactions = \"deploy\"\n\n[actions.test]\ncommand = \"pnpm test\"\n"
        }
      },
      "expected": [
        {
          "provider": "codex",
          "label": "Codex environment",
          "files": [
            ".codex/environments/environment.toml"
          ],
          "setup": "npm ci\npnpm build",
          "archive": "pnpm clean",
          "unsupportedFields": [
            "actions",
            "[actions.test]"
          ]
        }
      ]
    },
    {
      "function": "inspectSetupScriptImportCandidates",
      "note": "cmux project config: keyword+command match selects setup command; unknown fields flagged",
      "input": {
        "contentsByPath": {
          ".cmux/cmux.json": "{\"commands\":[{\"name\":\"Run Unit Tests\",\"keywords\":[\"test\"],\"command\":\"./scripts/test.sh\"},{\"name\":\"Bootstrap deps\",\"keywords\":[\"install\"],\"command\":\"./scripts/setup.sh --full\",\"confirm\":true,\"cwd\":\"packages/app\"}]}"
        }
      },
      "expected": [
        {
          "provider": "cmux",
          "label": "cmux",
          "files": [
            ".cmux/cmux.json"
          ],
          "setup": "./scripts/setup.sh --full",
          "unsupportedFields": [
            "commands.1.confirm",
            "commands.1.cwd"
          ]
        }
      ]
    },
    {
      "function": "inspectSetupScriptImportCandidates",
      "note": "cmux root config fallback when the project config has no setup command",
