      "expected": {
        "agent": "mistral-vibe",
        "launchCommand": "vibe",
        "expectedProcess": "vibe",
        "followupPrompt": "fix it"
      }
    },
    {
      "function": "buildAgentStartupPlan",
      "note": "leaves Claude command overrides untouched",
      "input": {
        "agent": "claude",
