--- a/crates/aterm-core/src/terminal/handler_csi.rs
+++ b/crates/aterm-core/src/terminal/handler_csi.rs
@@ -516,8 +516,14 @@ impl TerminalHandler<'_> {
                 // XTVERSION: CSI > Ps q — Query terminal version.
                 let ps = params.first().copied().unwrap_or(0);
                 if ps == 0 {
-                    let response =
-                        format!("\x1bP>|aterm({})\x1b\\", aterm_types::version::APP_VERSION);
+                    // wasm-build downstream shim: emit the DA marker as one
+                    // compile-time literal so the version stays contiguous in
+                    // rodata. orca's aterm-pin gate greps `aterm(x.y.z)` from
+                    // the blob to prove wasm⇔submodule agreement; the APP_VERSION
+                    // indirection (engine bbb16794) splits it. In wasm builds
+                    // ATERM_APP_RELEASE_VERSION is unset, so APP_VERSION ==
+                    // CARGO_PKG_VERSION — behaviour is identical.
+                    let response = concat!("\x1bP>|aterm(", env!("CARGO_PKG_VERSION"), ")\x1b\\");
                     self.send_response(cap, response.as_bytes());
