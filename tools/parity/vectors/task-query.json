        "scope": "all",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": ["bug", "needs review"],
        "freeText": ""
      }
    },
    {
      "function": "serializeTaskQuery",
      "note": "round-trips qualifiers and free text in serializer field order",
      "input": {
        "scope": "pr",
        "state": "open",
        "draft": false,
        "assignee": null,
        "author": "alice",
        "reviewRequested": "bob",
        "reviewedBy": null,
        "labels": ["bug"],
        "freeText": "hello world"
      },
      "expected": "is:pr is:open author:alice review-requested:bob label:bug hello world"
    },
    {
      "function": "serializeTaskQuery",
      "note": "quotes label values containing whitespace",
      "input": {
        "scope": "all",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": ["needs review"],
        "freeText": ""
      },
      "expected": "label:\"needs review\""
    },
    {
      "function": "serializeTaskQuery",
      "note": "serializes all state so filter changes do not fall back to the default open state",
      "input": {
        "scope": "pr",
        "state": "all",
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      },
      "expected": "is:pr state:all"
    },
    {
      "function": "serializeTaskQuery",
      "note": "all-default query serializes to the empty string",
      "input": {
        "scope": "all",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      },
      "expected": ""
    },
    {
      "function": "serializeTaskQuery",
