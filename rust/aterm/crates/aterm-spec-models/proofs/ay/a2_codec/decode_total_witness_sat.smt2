; Err path: this witness byte is NOT in the alphabet => decode_byte returns Err.
(assert (= (DECODE byte) (_ bv255 8)))            ; table[byte] == 0xFF (sentinel)
(assert (bvult byte (_ bv128 8)))                 ; an ASCII non-alphabet byte (e.g. '!','=',space)

; Ok path is real too: a fixed alphabet byte decodes to an in-range 0..63 index.
(assert (= (DECODE (_ bv65 8)) (_ bv0  8)))       ; 'A' -> 0   (Ok)
(assert (= (DECODE (_ bv47 8)) (_ bv63 8)))       ; '/' -> 63  (Ok)
(assert (bvult (DECODE (_ bv65 8)) (_ bv64 8)))   ; Ok value is a valid sextet (< 64)
(check-sat)
