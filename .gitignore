# Build artifacts
tsconfig.*.tsbuildinfo

# TypeScript emit artifacts next to sources (tsc produced these accidentally;
# real source lives in .ts/.tsx). Hand-authored declaration files are
# re-included below.
src/**/*.js
src/**/*.d.ts
/electron.vite.config.js
/electron.vite.config.d.ts
!src/main/types/hosted-git-info.d.ts
!src/preload/api-types.d.ts
!src/preload/index.d.ts
!src/renderer/src/env.d.ts
!src/renderer/src/mermaid.d.ts
!src/types/build-constants.d.ts

# aterm wasm-bindgen glue: track the JS + .d.ts bindings WITH the committed _bg.wasm
# binaries so a pull updates both ABI halves atomically (else a fresh clone is missing
# the imports the renderer hard-imports, and a wasm bump can silently drift from glue).
!src/renderer/src/lib/pane-manager/aterm/aterm_wasm.js
!src/renderer/src/lib/pane-manager/aterm/aterm_wasm.d.ts
!src/renderer/src/lib/pane-manager/aterm/aterm_wasm_bg.wasm.d.ts
!src/renderer/src/lib/pane-manager/aterm/aterm_gpu_web.js
!src/renderer/src/lib/pane-manager/aterm/aterm_gpu_web.d.ts
!src/renderer/src/lib/pane-manager/aterm/aterm_gpu_web_bg.wasm.d.ts

# orca-git wasm-bindgen glue for the addon-less SSH relay: commit the JS + .d.ts
# bindings and the base64-embedded bytes (orca_git_wasm_bg.wasm.base64.ts, which
# the relay imports) so a fresh clone builds without regenerating. The raw
# _bg.wasm is redundant with the base64 module, so it is NOT committed.
!src/relay/wasm/orca_git_wasm.js
!src/relay/wasm/orca_git_wasm.d.ts
!src/relay/wasm/orca_git_wasm_bg.wasm.d.ts
src/relay/wasm/orca_git_wasm_bg.wasm

# The RENDERER's copy of the same orca-git glue (loaded via vite `?url` + async
# init, the aterm precedent). Here the raw _bg.wasm IS committed (tracked by
# default — no unignore needed) so `?url` imports work from a fresh clone.
!src/renderer/src/lib/git-wasm/orca_git_wasm.js
!src/renderer/src/lib/git-wasm/orca_git_wasm.d.ts
!src/renderer/src/lib/git-wasm/orca_git_wasm_bg.wasm.d.ts

# orca-crypto wasm-bindgen glue for the app's E2EE. The Node main/CLI processes
# import the base64-embedded bytes (orca_crypto_wasm_bg.wasm.base64.ts); the raw
# _bg.wasm there is redundant with the base64 module, so NOT committed.
!src/shared/crypto-wasm/orca_crypto_wasm.js
!src/shared/crypto-wasm/orca_crypto_wasm.d.ts
!src/shared/crypto-wasm/orca_crypto_wasm_bg.wasm.d.ts
src/shared/crypto-wasm/orca_crypto_wasm_bg.wasm
# The RENDERER's copy of the same crypto glue (loaded via vite `?url` + async
# init). Here the raw _bg.wasm IS committed so `?url` imports work from a fresh
# clone.
!src/renderer/src/lib/crypto-wasm/orca_crypto_wasm.js
!src/renderer/src/lib/crypto-wasm/orca_crypto_wasm.d.ts
!src/renderer/src/lib/crypto-wasm/orca_crypto_wasm_bg.wasm.d.ts

# Dependencies
node_modules/

