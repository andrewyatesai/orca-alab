          { "method": "rebase", "label": "Rebase and merge" }
        ]
      }
    },
    {
      "function": "mapGitHubDefaultMergeMethod",
      "note": "uppercase GitHub enum id maps to the lowercase method id",
      "input": "MERGE",
      "expected": "merge"
    },
    {
      "function": "mapGitHubDefaultMergeMethod",
      "note": "value is upper-cased before matching, so lowercase still resolves",
      "input": "rebase",
      "expected": "rebase"
