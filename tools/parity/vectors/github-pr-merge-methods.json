    },
    {
      "function": "normalizeGitHubPRMergeMethodSettings",
      "note": "no method allowed but a mappable default keeps that default (firstAllowed ?? defaultMethod)",
      "input": {
        "defaultMethod": "MERGE",
        "mergeCommitAllowed": false,
        "rebaseMergeAllowed": false,
        "squashMergeAllowed": false
      },
      "expected": {
        "defaultMethod": "merge",
        "allowedMethods": { "squash": false, "merge": false, "rebase": false }
      }
