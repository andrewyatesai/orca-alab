    {
      "function": "buildAgentStartupPlan",
      "note": "POSIX quoting when the target shell is Linux",
      "input": {
        "agent": "claude",
        "prompt": "fix Bob's branch",
        "cmdOverrides": {},
        "platform": "linux"
      },
      "expected": {
        "agent": "claude",
        "launchCommand": "claude 'fix Bob'\\''s branch'",
        "expectedProcess": "claude",
        "followupPrompt": null,
        "launchConfig": {
          "agentCommand": "claude",
          "agentArgs": "",
          "agentEnv": {}
        }
      }
    },
