        "scope": "pr",
        "state": "all",
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "is:merged forces pr scope after the loop",
      "input": "is:merged",
      "expected": {
        "scope": "pr",
        "state": "merged",
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "reviewed-by forces pr scope",
      "input": "reviewed-by:bob",
      "expected": {
        "scope": "pr",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
