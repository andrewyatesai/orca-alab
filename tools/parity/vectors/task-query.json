        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "keeps draft scoped to open PRs even when a later token says issue",
      "input": "is:draft is:issue",
      "expected": {
        "scope": "pr",
        "state": "open",
        "draft": true,
        "assignee": null,
        "author": null,
        "reviewRequested": null,
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
      "note": "is:pr is:open does not set draft",
      "input": "is:pr is:open",
      "expected": {
        "scope": "pr",
        "state": "open",
        "draft": false,
