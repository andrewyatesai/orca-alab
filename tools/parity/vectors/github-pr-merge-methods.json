    {
      "function": "normalizeGitHubPRMergeMethodSettings",
      "note": "uses GitHub viewer default and records which methods the repo allows",
      "input": {
        "defaultMethod": "REBASE",
        "mergeCommitAllowed": false,
        "rebaseMergeAllowed": true,
        "squashMergeAllowed": true
      },
      "expected": {
        "defaultMethod": "rebase",
        "allowedMethods": { "squash": true, "merge": false, "rebase": true }
      }
    },
    {
      "function": "resolveGitHubPRMergeMethods",
      "note": "uses GitHub viewer default and hides methods disabled by the repository",
      "input": {
        "defaultMethod": "rebase",
        "allowedMethods": { "squash": true, "merge": false, "rebase": true }
      },
      "expected": {
        "defaultMethod": "rebase",
        "defaultLabel": "Rebase and merge",
        "methods": [
          { "method": "rebase", "label": "Rebase and merge" },
          { "method": "squash", "label": "Squash and merge" }
        ]
      }
    },
    {
      "function": "normalizeGitHubPRMergeMethodSettings",
      "note": "falls back to an allowed method when GitHub returns a disabled default",
      "input": {
        "defaultMethod": "SQUASH",
        "mergeCommitAllowed": true,
        "rebaseMergeAllowed": false,
        "squashMergeAllowed": false
      },
      "expected": {
        "defaultMethod": "merge",
        "allowedMethods": { "squash": false, "merge": true, "rebase": false }
      }
    },
    {
      "function": "resolveGitHubPRMergeMethods",
      "note": "single allowed method yields a one-entry presentation",
      "input": {
        "defaultMethod": "merge",
        "allowedMethods": { "squash": false, "merge": true, "rebase": false }
      },
      "expected": {
        "defaultMethod": "merge",
        "defaultLabel": "Create merge commit",
        "methods": [{ "method": "merge", "label": "Create merge commit" }]
