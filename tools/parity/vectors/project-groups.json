            "connectionId": "c1"
          },
          {
            "id": "free",
            "path": "/free",
            "displayName": "free",
            "badgeColor": "#777",
            "addedAt": 3,
            "kind": "git",
            "projectGroupId": null
          }
        ],
        "groups": [
          {
            "id": "g1"
          }
        ]
      },
      "expected": [
        {
          "id": "known",
          "path": "/known",
          "displayName": "known",
          "badgeColor": "#999",
          "addedAt": 1,
          "kind": "git",
          "projectGroupId": "g1"
        },
        {
          "id": "orphan",
          "path": "/orphan",
          "displayName": "orphan",
          "badgeColor": "#888",
          "addedAt": 2,
          "kind": "git",
          "projectGroupId": null,
          "connectionId": "c1"
        },
        {
          "id": "free",
          "path": "/free",
          "displayName": "free",
          "badgeColor": "#777",
          "addedAt": 3,
          "kind": "git",
