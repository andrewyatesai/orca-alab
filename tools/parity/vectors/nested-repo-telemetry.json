      "expected": false
    },
    {
      "function": "shouldEmitNestedRepoImportSubmitTelemetry",
      "note": "busy submit never emits",
      "input": { "attemptId": "2fbac1e3-5094-45b4-80a6-90281e6e9e09", "selectedCount": 1, "isBusy": true },
      "expected": false
    },
    {
      "function": "shouldEmitNestedRepoImportSubmitTelemetry",
