--- a/crates/trust-vcgen/src/guards.rs
+++ b/crates/trust-vcgen/src/guards.rs
@@ -193,6 +193,24 @@ fn latest_same_block_bool_definition(
         let Rvalue::BinaryOp(op, lhs, rhs) = rvalue else {
