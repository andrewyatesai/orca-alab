      "expected": {
        "scope": "pr",
        "state": null,
        "draft": false,
        "assignee": null,
        "author": null,
        "reviewRequested": "@me",
        "reviewedBy": null,
        "labels": [],
        "freeText": ""
      }
    },
    {
      "function": "parseTaskQuery",
