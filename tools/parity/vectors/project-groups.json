{
  "module": "project-groups",
  "source": "src/shared/project-groups.ts",
  "rustCrate": "orca-config::project_groups",
  "cases": [
    {
      "function": "normalizeProjectGroupName",
      "note": "trims surrounding whitespace, keeps content (default fallback unused)",
      "input": {
        "name": "  Platform  "
      },
      "expected": "Platform"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "blank name falls back to the provided fallback",
      "input": {
        "name": "   ",
        "fallback": "Existing"
      },
      "expected": "Existing"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "blank name with no fallback uses the default 'Untitled group'",
      "input": {
        "name": ""
      },
      "expected": "Untitled group"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "tabs/newlines-only name is blank after trim, uses fallback",
      "input": {
        "name": "\t\n ",
        "fallback": "Custom"
      },
      "expected": "Custom"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "already-clean name returned unchanged",
      "input": {
        "name": "Backend Services"
      },
      "expected": "Backend Services"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "internal whitespace preserved, only the edges are trimmed",
      "input": {
        "name": "  My   Group  "
      },
      "expected": "My   Group"
    },
    {
      "function": "getNextProjectGroupOrder",
      "note": "next order inside a group ignores ungrouped repos",
      "input": {
        "repos": [
          {
            "id": "a",
            "projectGroupId": "g",
            "projectGroupOrder": 2
          },
          {
            "id": "b",
            "projectGroupId": null,
            "projectGroupOrder": 9
          }
        ],
        "groupId": "g"
      },
      "expected": 3
    },
    {
      "function": "getNextProjectGroupOrder",
      "note": "empty repo list yields 0",
      "input": {
        "repos": [],
        "groupId": null
      },
      "expected": 0
    },
    {
      "function": "getNextProjectGroupOrder",
      "note": "null group computes from null-group repos only",
      "input": {
        "repos": [
          {
            "id": "a",
            "projectGroupId": null,
            "projectGroupOrder": 4
          },
          {
            "id": "b",
            "projectGroupId": "g",
            "projectGroupOrder": 10
          }
        ],
        "groupId": null
      },
      "expected": 5
    },
    {
      "function": "getNextProjectGroupOrder",
      "note": "no repos in the target group yields 0",
      "input": {
        "repos": [
          {
            "id": "a",
            "projectGroupId": "other",
            "projectGroupOrder": 7
          }
        ],
        "groupId": "g"
      },
      "expected": 0
    },
    {
      "function": "getNextProjectGroupOrder",
      "note": "non-finite order (NaN/Infinity persist as null) is ignored; max of finite orders + 1",
      "input": {
        "repos": [
          {
            "id": "a",
            "projectGroupId": "g",
            "projectGroupOrder": null
          },
          {
            "id": "b",
            "projectGroupId": "g",
            "projectGroupOrder": 2
          }
        ],
        "groupId": "g"
      },
      "expected": 3
    },
    {
      "function": "getProjectGroupSubtreeIds",
      "note": "collects the root plus all transitive descendants (returned sorted; the TS Set is membership-only at every call site)",
      "input": {
        "groups": [
          {
            "id": "root",
            "parentGroupId": null
          },
          {
            "id": "child",
            "parentGroupId": "root"
          },
          {
            "id": "grandchild",
            "parentGroupId": "child"
          },
          {
            "id": "sibling",
            "parentGroupId": null
          }
        ],
        "rootGroupId": "root"
      },
      "expected": [
        "child",
        "grandchild",
        "root"
      ]
    },
    {
      "function": "getProjectGroupSubtreeIds",
      "note": "multiple branches under the root are all collected",
      "input": {
        "groups": [
          {
            "id": "root",
            "parentGroupId": null
          },
          {
            "id": "a",
            "parentGroupId": "root"
          },
          {
            "id": "b",
            "parentGroupId": "root"
          },
          {
            "id": "a1",
            "parentGroupId": "a"
          }
        ],
        "rootGroupId": "root"
      },
      "expected": [
        "a",
        "a1",
        "b",
        "root"
      ]
    },
    {
      "function": "getProjectGroupSubtreeIds",
      "note": "a self-parent cycle terminates and yields just that id (no infinite loop)",
      "input": {
        "groups": [
          {
            "id": "a",
            "parentGroupId": "a"
          }
        ],
        "rootGroupId": "a"
      },
      "expected": [
        "a"
      ]
    },
    {
      "function": "getProjectGroupSubtreeIds",
      "note": "a root absent from the group list still yields itself (the traversal seeds it regardless)",
      "input": {
        "groups": [
          {
            "id": "a",
            "parentGroupId": null
          }
        ],
        "rootGroupId": "zzz"
      },
      "expected": [
        "zzz"
      ]
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "leading BOM (U+FEFF) is stripped by JS trim, so the name keeps its content (guards trim_js vs str::trim)",
      "input": {
        "name": "﻿Platform"
      },
      "expected": "Platform"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "trailing U+0085 (NEL) is NOT stripped by JS trim, so it stays in the name",
      "input": {
        "name": "Platform"
      },
      "expected": "Platform"
    },
    {
      "function": "normalizeProjectGroupName",
      "note": "a bare-BOM name is blank after JS trim, so it falls back to the default",
      "input": {
        "name": "﻿"
      },
      "expected": "Untitled group"
    },
    {
      "function": "createProjectGroup",
      "note": "assembles a durable group with normalized name + injected id/clock; no executionHostId (the factory never sets it)",
      "input": {
        "id": "grp-1",
        "name": "  Platform  ",
        "parentPath": "/srv/platform",
        "connectionId": null,
        "parentGroupId": null,
        "createdFrom": "folder-scan",
        "tabOrder": 3,
        "now": 100
      },
      "expected": {
        "id": "grp-1",
        "name": "Platform",
        "parentPath": "/srv/platform",
        "connectionId": null,
        "parentGroupId": null,
        "createdFrom": "folder-scan",
        "tabOrder": 3,
        "isCollapsed": false,
        "color": null,
        "createdAt": 100,
        "updatedAt": 100
      }
    },
    {
      "function": "createProjectGroup",
      "note": "carries connectionId + parentGroupId; a blank name falls back to Untitled group",
      "input": {
        "id": "grp-2",
        "name": "   ",
        "parentPath": null,
        "connectionId": "conn-1",
        "parentGroupId": "grp-1",
        "createdFrom": "manual",
        "tabOrder": 0,
        "now": 50
      },
      "expected": {
        "id": "grp-2",
        "name": "Untitled group",
        "parentPath": null,
        "connectionId": "conn-1",
        "parentGroupId": "grp-1",
        "createdFrom": "manual",
        "tabOrder": 0,
        "isCollapsed": false,
        "color": null,
        "createdAt": 50,
        "updatedAt": 50
      }
    },
    {
      "function": "normalizeProjectGroups",
      "note": "dedupes by id, drops entries without a string id, sorts by tabOrder, and nulls a dangling parentGroupId",
      "input": {
        "value": [
          {
            "id": "b",
            "name": "B",
            "tabOrder": 2
          },
          {
            "id": "a",
            "name": "A",
            "tabOrder": 1,
            "parentGroupId": "missing",
            "createdFrom": "folder-scan",
            "isCollapsed": true
          },
          {
            "id": "a",
            "name": "duplicate"
          },
          {
            "name": "missing id"
          }
        ],
        "now": 0
      },
      "expected": [
        {
          "id": "a",
          "name": "A",
          "parentPath": null,
          "connectionId": null,
          "parentGroupId": null,
          "createdFrom": "folder-scan",
          "tabOrder": 1,
          "isCollapsed": true,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0
        },
        {
          "id": "b",
          "name": "B",
          "parentPath": null,
          "connectionId": null,
          "parentGroupId": null,
          "createdFrom": "manual",
          "tabOrder": 2,
          "isCollapsed": false,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0
        }
      ]
    },
    {
      "function": "normalizeProjectGroups",
      "note": "preserves a string connectionId and normalizes executionHostId; a non-string connectionId becomes null and a malformed ssh host is dropped",
      "input": {
        "value": [
          {
            "id": "remote",
            "name": "Remote",
            "tabOrder": 1,
            "connectionId": "conn-9",
            "executionHostId": "ssh:host%20a"
          },
          {
            "id": "bad",
            "name": "Bad",
            "tabOrder": 2,
            "connectionId": 42,
            "executionHostId": "ssh:"
          },
          {
            "id": "loc",
            "name": "Local",
            "tabOrder": 3,
            "executionHostId": "local"
          }
        ],
        "now": 0
      },
      "expected": [
        {
          "id": "remote",
          "name": "Remote",
          "parentPath": null,
          "connectionId": "conn-9",
          "parentGroupId": null,
          "createdFrom": "manual",
          "tabOrder": 1,
          "isCollapsed": false,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0,
          "executionHostId": "ssh:host%20a"
        },
        {
          "id": "bad",
          "name": "Bad",
          "parentPath": null,
          "connectionId": null,
          "parentGroupId": null,
          "createdFrom": "manual",
          "tabOrder": 2,
          "isCollapsed": false,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0
        },
        {
          "id": "loc",
          "name": "Local",
          "parentPath": null,
          "connectionId": null,
          "parentGroupId": null,
          "createdFrom": "manual",
          "tabOrder": 3,
          "isCollapsed": false,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0,
          "executionHostId": "local"
        }
      ]
    },
    {
      "function": "normalizeProjectGroups",
      "note": "equal tabOrder breaks ties case-insensitively (localeCompare best-effort): apple sorts before Banana",
      "input": {
        "value": [
          {
            "id": "b",
            "name": "Banana",
            "tabOrder": 0
          },
          {
            "id": "a",
            "name": "apple",
            "tabOrder": 0
          }
        ],
        "now": 0
      },
      "expected": [
        {
          "id": "a",
          "name": "apple",
          "parentPath": null,
          "connectionId": null,
          "parentGroupId": null,
          "createdFrom": "manual",
          "tabOrder": 0,
          "isCollapsed": false,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0
        },
        {
          "id": "b",
          "name": "Banana",
          "parentPath": null,
          "connectionId": null,
          "parentGroupId": null,
          "createdFrom": "manual",
          "tabOrder": 0,
          "isCollapsed": false,
          "color": null,
          "createdAt": 0,
          "updatedAt": 0
        }
      ]
    },
    {
      "function": "clearMissingProjectGroupMemberships",
      "note": "nulls a dead projectGroupId while preserving every other repo field verbatim; live + null memberships pass through unchanged",
      "input": {
        "repos": [
          {
            "id": "known",
            "path": "/known",
            "displayName": "known",
            "badgeColor": "#999",
            "addedAt": 1,
            "kind": "git",
            "projectGroupId": "g1"
          },
          {
            "id": "orphan",
            "path": "/orphan",
            "displayName": "orphan",
            "badgeColor": "#888",
            "addedAt": 2,
            "kind": "git",
