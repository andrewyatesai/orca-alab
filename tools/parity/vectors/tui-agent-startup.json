{
  "module": "tui-agent-startup",
  "source": "src/shared/tui-agent-startup.ts",
  "rustCrate": "orca-agents::tui_agent_startup",
  "cases": [
    {
      "function": "buildAgentStartupPlan",
      "note": "POSIX quoting when the target shell is Linux",
      "input": { "agent": "claude", "prompt": "fix Bob's branch", "cmdOverrides": {}, "platform": "linux" },
      "expected": {
        "agent": "claude",
        "launchCommand": "claude 'fix Bob'\\''s branch'",
        "expectedProcess": "claude",
        "followupPrompt": null
      }
    },
    {
      "function": "buildAgentStartupPlan",
      "note": "PowerShell quoting by default on Windows",
      "input": { "agent": "claude", "prompt": "fix Bob's \"quoted\" branch", "cmdOverrides": {}, "platform": "win32" },
      "expected": {
        "agent": "claude",
        "launchCommand": "claude 'fix Bob''s \"quoted\" branch'",
        "expectedProcess": "claude",
        "followupPrompt": null
      }
    },
    {
      "function": "buildAgentStartupPlan",
      "note": "cmd escaping when requested explicitly",
      "input": { "agent": "claude", "prompt": "fix \"quoted\" & %PATH%", "cmdOverrides": {}, "platform": "win32", "shell": "cmd" },
      "expected": {
        "agent": "claude",
        "launchCommand": "claude \"fix ^\"quoted^\" ^& ^%PATH^%\"",
        "expectedProcess": "claude",
        "followupPrompt": null
      }
    },
    {
      "function": "buildAgentStartupPlan",
      "note": "does not launch Codex with the Orca profile",
      "input": { "agent": "codex", "prompt": "fix it", "cmdOverrides": {}, "platform": "linux" },
      "expected": {
        "agent": "codex",
        "launchCommand": "codex 'fix it'",
        "expectedProcess": "codex",
        "followupPrompt": null
      }
    },
    {
      "function": "buildAgentStartupPlan",
      "note": "launches Claude without Orca settings injection",
