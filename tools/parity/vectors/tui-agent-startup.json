    {
      "function": "buildAgentDraftLaunchPlan",
      "note": "clears the pi draft env var with PowerShell syntax",
      "input": {
        "agent": "pi",
        "draft": "https://github.com/acme/repo/issues/42",
        "cmdOverrides": {},
        "platform": "win32"
      },
      "expected": {
        "agent": "pi",
        "launchCommand": "pi; Remove-Item Env:ORCA_PI_PREFILL -ErrorAction SilentlyContinue",
        "expectedProcess": "pi",
        "env": { "ORCA_PI_PREFILL": "https://github.com/acme/repo/issues/42" }
      }
    },
    {
      "function": "buildAgentDraftLaunchPlan",
      "note": "clears the pi draft env var with cmd syntax",
      "input": {
        "agent": "pi",
        "draft": "https://github.com/acme/repo/issues/42",
        "cmdOverrides": {},
        "platform": "win32",
        "shell": "cmd"
      },
      "expected": {
        "agent": "pi",
        "launchCommand": "pi & set \"ORCA_PI_PREFILL=\"",
        "expectedProcess": "pi",
        "env": { "ORCA_PI_PREFILL": "https://github.com/acme/repo/issues/42" }
      }
    },
    {
      "function": "buildAgentDraftLaunchPlan",
      "note": "OMP draft plan uses ORCA_OMP_PREFILL (OMP-scoped, not Pi-shared)",
      "input": {
        "agent": "omp",
        "draft": "fix the omp regression",
        "cmdOverrides": {},
        "platform": "linux"
      },
      "expected": {
        "agent": "omp",
        "launchCommand": "omp; unset ORCA_OMP_PREFILL",
        "expectedProcess": "omp",
        "env": { "ORCA_OMP_PREFILL": "fix the omp regression" }
      }
    }
  ]
