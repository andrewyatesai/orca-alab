    {
      "function": "capNestedRepoTelemetryCount",
      "note": "NaN persists to JSON null; non-finite returns 0",
      "input": null,
      "expected": 0
    },
    {
      "function": "capNestedRepoTelemetryCount",
      "note": "above-max clamps to NESTED_REPO_TELEMETRY_MAX_REPO_COUNT (500)",
      "input": 999,
      "expected": 500
    },
    {
      "function": "bucketNestedRepoTelemetryCount",
      "note": "0 bucket",
      "input": 0,
      "expected": "0"
    },
    {
      "function": "bucketNestedRepoTelemetryCount",
      "note": "1 bucket",
      "input": 1,
      "expected": "1"
    },
    {
